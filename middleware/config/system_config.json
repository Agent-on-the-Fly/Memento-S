{
  "version": "0.2.0",
  "app": {
    "name": "Memento-S",
    "theme_options": {
      "system": {
        "zh-CN": "跟随系统",
        "en-US": "System"
      },
      "light": {
        "zh-CN": "亮色",
        "en-US": "Light"
      },
      "dark": {
        "zh-CN": "暗色",
        "en-US": "Dark"
      }
    },
    "language_options": {
      "zh-CN": {
        "zh-CN": "中文",
        "en-US": "Chinese"
      },
      "en-US": {
        "zh-CN": "Chinese",
        "en-US": "English"
      }
    }
  },
  "skills": {
    "catalog_path": "router_data/skills_catalog.jsonl",
    "github_mirrors": [
      "https://gh-proxy.com/"
    ],
    "cloud_catalog_url": "https://skills.yangtzeailab.com/",
    "retrieval": {
      "top_k": 5,
      "min_score": 0.012,
      "embedding_model": "Qwen3-Embedding-4B",
      "embedding_dimension": 2560,
      "embedding_base_url": "https://skills.yangtzeailab.com/api/v1",
      "embedding_api_key": "sk-xxxxxx",
      "reranker_enabled": true,
      "reranker_min_score": 0.001
    },
    "execution": {
      "timeout_sec": 300,
      "max_reflection_retries": 3,
      "sandbox_provider": "uv",
      "uv_python_version": "3.12",
      "bash_timeout_sec": 300,
      "pip_install_timeout_sec": 180,
      "cli_install_timeout_sec": 300,
      "max_attempts": 3,
      "same_signature_limit": 2
    }
  },
  "paths": {
    "workspace_dir": null,
    "skills_dir": null,
    "db_dir": null,
    "logs_dir": null,
    "venv_dir": null,
    "path_validation_enabled": false
  },
  "logging": {
    "level": "INFO"
  },
  "agent": {
    "max_iterations": 100
  },
  "gateway": {
    "enabled": true,
    "mode": "gateway",
    "websocket_host": "127.0.0.1",
    "websocket_port": 8765,
    "webhook_host": "127.0.0.1",
    "webhook_port": 18080
  },
  "ota": {
    "url": "https://ota.yangtzeailab.com/api/v1/check_for_updates"
  },
  "auth": {
    "base_url": "https://ota.yangtzeailab.com/"
  }
}